{
  "firefox": {
    "MOZ_ENABLE_WAYLAND": "1"
  },
  "chromium": {
    "CHROMIUM_FLAGS": "--ozone-platform=wayland"
  },
  "foot": {
    "FOOT_EXTRA_CONFIG": "~/.config/sway/config"
  },
  "/usr/bin/steam": {
    "STEAM_RUNTIME": "1",
    "LD_PRELOAD": "/usr/lib/steam/steam-runtime/lib/x86_64-linux-gnu/libstdc++.so.6"
  }
}
